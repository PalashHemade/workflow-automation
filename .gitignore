# ────────────────────────────────────────────────────────────
#  Next.js + Prisma + Node — .gitignore
# ────────────────────────────────────────────────────────────

# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Next.js build output ──────────────────────────────────────
.next/
out/
build/

# ── TypeScript incremental build info ────────────────────────
tsconfig.tsbuildinfo
*.tsbuildinfo

# ── Environment variables ─────────────────────────────────────
# Never commit secrets. Keep .env.example (no real values) in git.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# ── Prisma ───────────────────────────────────────────────────
# Generated client — rebuilt via `prisma generate`
prisma/generated/

# ── Logs ─────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ── OS / editor junk ─────────────────────────────────────────
.DS_Store
Thumbs.db
*.suo
*.user
.idea/
.vscode/settings.json
.vscode/launch.json

# ── Package manager lock files (keep one) ─────────────────────
# If you use npm keep package-lock.json and ignore the rest:
yarn.lock
pnpm-lock.yaml

# ── Misc ─────────────────────────────────────────────────────
*.pem
.vercel
.turbo
