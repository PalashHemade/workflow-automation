datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// NextAuth.js Models for OAuth Authentication
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  repositories  Repository[]
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Repository Analytics Domain Models
model Repository {
  id             String        @id @default(cuid())
  githubId       BigInt        @unique // GitHub's internal repository ID
  name           String
  owner          String
  fullName       String
  htmlUrl        String
  isTracked      Boolean       @default(false)
  webhookEnabled Boolean       @default(false) // Tracks if webhooks are set up
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackingUserIds String       @default("")

  
  // Metadata for Incremental Sync
  displayName             String?
  isArchived              Boolean        @default(false)
  lastSyncedAt            DateTime?
  lastSuccessfulSyncAt    DateTime?
  lastFailedSyncAt        DateTime?
  lastSuccessfulCommitSha String?
  lastProcessedPullRequest Int?
  syncStatus              String         @default("idle") // idle, syncing, success, failed
  lastSyncError           String?        @db.Text
  syncFailureCount        Int            @default(0)
  nextAllowedSyncAt       DateTime?
  pollingInterval         Int            @default(60) // in minutes
  
  commits        Commit[]
  pullRequests   PullRequest[]
  branches       Branch[]
  webhookEvents  WebhookEvent[]
  webhook        RepositoryWebhook?
  syncLogs       BackgroundSyncLog[]
  projectEvents  ProjectEvent[]
}

model Contributor {
  id             String        @id @default(cuid())
  githubId       BigInt?       @unique // GitHub User ID
  login          String        @unique // GitHub User login/username
  name           String?
  email          String?
  avatarUrl      String?
  
  commits        Commit[]
  pullRequests   PullRequest[]
  reviews        Review[]
  reviewComments ReviewComment[]
}

model Commit {
  id             String       @id @default(cuid())
  sha            String       @unique // Commit hash
  message        String
  url            String
  committedAt    DateTime
  
  repositoryId   String
  repository     Repository   @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  
  contributorId  String?
  contributor    Contributor? @relation(fields: [contributorId], references: [id], onDelete: SetNull)
  authorName     String
  authorEmail    String
  authorAvatar   String?

  files          CommitFile[]

  @@index([repositoryId])
  @@index([committedAt])
}

model PullRequest {
  id             String       @id @default(cuid())
  githubId       BigInt       @unique // GitHub Pull Request node ID
  number         Int          // PR number in repository
  title          String
  state          String       // open, closed, merged
  url            String
  createdAt      DateTime
  updatedAt      DateTime
  closedAt       DateTime?
  mergedAt       DateTime?
  merged         Boolean      @default(false)
  
  repositoryId   String
  repository     Repository   @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  
  contributorId  String?
  contributor    Contributor? @relation(fields: [contributorId], references: [id], onDelete: SetNull)
  authorName     String
  authorEmail    String
  authorAvatar   String?

  files          PullRequestFile[]
  reviews        Review[]
  comments       ReviewComment[]

  @@index([repositoryId])
  @@index([createdAt])
}

model CommitFile {
  id             String   @id @default(cuid())
  commitId       String
  commit         Commit   @relation(fields: [commitId], references: [id], onDelete: Cascade)
  filename       String
  status         String   // added, modified, removed, renamed
  additions      Int
  deletions      Int
  changes        Int
  patch          String?  @db.Text // Unified diff/patch

  @@index([commitId])
}

model PullRequestFile {
  id             String      @id @default(cuid())
  pullRequestId  String
  pullRequest    PullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  filename       String
  status         String
  additions      Int
  deletions      Int
  changes        Int
  patch          String?     @db.Text

  @@index([pullRequestId])
}

model Review {
  id             String         @id @default(cuid())
  githubId       BigInt         @unique
  pullRequestId  String
  pullRequest    PullRequest    @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  contributorId  String?
  contributor    Contributor?   @relation(fields: [contributorId], references: [id], onDelete: SetNull)
  authorName     String
  authorAvatar   String?
  body           String?        @db.Text
  state          String         // APPROVED, CHANGES_REQUESTED, COMMENTED, DISMISSED, etc.
  submittedAt    DateTime
  comments       ReviewComment[]

  @@index([pullRequestId])
}

model ReviewComment {
  id             String       @id @default(cuid())
  githubId       BigInt       @unique
  pullRequestId  String
  pullRequest    PullRequest  @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  reviewId       String?
  review         Review?      @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  contributorId  String?
  contributor    Contributor? @relation(fields: [contributorId], references: [id], onDelete: SetNull)
  authorName     String
  authorAvatar   String?
  path           String
  line           Int?
  body           String       @db.Text
  diffHunk       String?      @db.Text
  createdAt      DateTime
  updatedAt      DateTime

  @@index([pullRequestId])
  @@index([reviewId])
}

model Branch {
  id             String     @id @default(cuid())
  name           String
  sha            String
  isDefault      Boolean    @default(false)
  isProtected    Boolean    @default(false)
  repositoryId   String
  repository     Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, name])
  @@index([repositoryId])
}

model WebhookEvent {
  id             String      @id @default(cuid())
  repositoryId   String?
  repository     Repository? @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  eventType      String      // push, pull_request, create, delete, pull_request_review, pull_request_review_comment
  action         String?     // opened, closed, synchronization, submitted, created, etc.
  payload        String      @db.Text
  processedAt    DateTime    @default(now())

  @@index([repositoryId])
  @@index([processedAt])
}

model RepositoryWebhook {
  id                     String     @id @default(cuid())
  repositoryId           String     @unique
  repository             Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  githubWebhookId        BigInt?    // Webhook ID returned by GitHub to allow automated deletion
  status                 String     @default("active") // active, inactive, failed
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  lastSuccessfulDelivery DateTime?
  lastDeliveryAttempt    DateTime?
  isActive               Boolean    @default(true)
}

model BackgroundSyncLog {
  id                String      @id @default(cuid())
  repositoryId      String?
  repository        Repository? @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  startedAt         DateTime    @default(now())
  completedAt       DateTime?
  syncType          String      // manual, webhook, scheduled
  status            String      // pending, running, completed, failed
  commitsProcessed  Int         @default(0)
  prsProcessed      Int         @default(0)
  durationMs        Int         @default(0)
  errorMsg          String?     @db.Text

  @@index([repositoryId])
  @@index([startedAt])
}

model BackgroundSyncStatus {
  id          String   @id @default("singleton")
  lastRunAt   DateTime @default(now())
  status      String   @default("healthy") // healthy, degraded, failing
  errorMsg    String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum EventType {
  COMMIT_CREATED
  PR_OPENED
  PR_UPDATED
  PR_CLOSED
  PR_MERGED
  REVIEW_SUBMITTED
  REVIEW_APPROVED
  CHANGES_REQUESTED
  REVIEW_COMMENT
  BRANCH_CREATED
  BRANCH_DELETED
  REPOSITORY_SYNCED
  SYNC_FAILED
  WEBHOOK_RECEIVED
}

enum EventImportance {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum EventSource {
  WEBHOOK
  SYNC
  MANUAL
  SYSTEM
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model ProjectEvent {
  id               String            @id @default(cuid())
  repositoryId     String
  repository       Repository        @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  eventType        EventType
  entityType       String            // e.g. Commit, PullRequest, Review, etc.
  entityId         String?           // ID of the entity in the DB
  parentEventId    String?           // Reference to parent ProjectEvent.id
  actorId          String?           // contributorId or userId
  actorName        String
  title            String            @db.Text
  description      String?           @db.Text
  importance       EventImportance
  source           EventSource
  version          Int               @default(1)
  processingStatus ProcessingStatus  @default(PENDING)
  processedAt      DateTime?
  metadata         Json              // Flexible schema-less details
  createdAt        DateTime          @default(now())

  @@index([repositoryId])
  @@index([createdAt])
  @@index([eventType])
  @@index([actorName])
}
